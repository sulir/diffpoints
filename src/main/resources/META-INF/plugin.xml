<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN. It cannot be changed between the plugin versions. -->
    <id>sk.tuke.diffpoints</id>

    <!-- Public plugin name should be written in Title Case.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-name -->
    <name>Diffpoints</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor email="filip.cmilnak@student.tuke.com" url="https://www.tuke.sk">TUKE</vendor>

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Simple HTML elements (text formatting, paragraphs, and lists) can be added inside of <![CDATA[ ]]> tag.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-description -->
    <description>
        Plugin for comparing variables at different points during debugging.
    </description>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <!-- Extension points defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
        <toolWindow factoryClass="sk.tuke.diffpoints.ToolWindowFactory" id="Diffpoints"
                    secondary="true" anchor="bottom"/>
        <applicationConfigurable
                parentId="tools"
                instance="sk.tuke.diffpoints.settings.DiffpointsConfigurable"
                id="sk.tuke.diffpoints.settings.DiffpointsConfigurable"
                displayName="Diffpoints"/>

        <xdebugger.breakpointType
                id="line-diffpoint-type"
                implementation="sk.tuke.diffpoints.breakpoints.LineDiffpointBreakpointType"/>
        <debugger.javaBreakpointHandlerFactory
                implementation="sk.tuke.diffpoints.breakpoints.LineDiffpointHandlerFactory"/>

        <xdebugger.breakpointType
            id="group-diffpoint-type"
            implementation="sk.tuke.diffpoints.breakpoints.GroupDiffpointBreakpointType"/>
        <debugger.javaBreakpointHandlerFactory
                implementation="sk.tuke.diffpoints.breakpoints.GroupDiffpointHandlerFactory"/>
    </extensions>

    <projectListeners>
        <listener class="sk.tuke.diffpoints.breakpoints.BreakpointHandler"
                  topic="com.intellij.debugger.impl.DebuggerManagerListener"/>
    </projectListeners>

    <actions>
        <action id="sk.tuke.diffpoints.actions.ToggleLineDiffpointAction"
                class="sk.tuke.diffpoints.actions.ToggleLineDiffpointAction"
                text="Add Line Diffpoint"
                description="Adds or removes a line diffpoint at the clicked gutter line">
            <add-to-group group-id="XDebugger.Hover.Breakpoint.Context.Menu" anchor="last"/>
        </action>
        <action id="sk.tuke.diffpoints.actions.ToggleGroupDiffpointAction"
                class="sk.tuke.diffpoints.actions.ToggleGroupDiffpointAction"
                text="Add Group Diffpoint"
                description="Adds or removes a group diffpoint at the clicked gutter line">
            <add-to-group group-id="XDebugger.Hover.Breakpoint.Context.Menu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>